#!/bin/sh
# cleanup Makefile targets
set -eu
THISDir=`dirname $0`
THISDir=`realpath ${THISDir}`
MAKE=`"${R_HOME}/bin/R" CMD config MAKE`
rm -rf inst/bcftools inst/htslib

if [ -f src/bcftools-1.23/Makefile ]; then
    ${MAKE} -C src/bcftools-1.23 distclean-all
fi

rm -f src/bcftools-1.23/libbcftools.so \
      src/bcftools-1.23/libbcftools.dylib \
      src/bcftools-1.23/htslib-1.23/hfile_*.so \
      src/bcftools-1.23/htslib-1.23/hfile_*.dylib
rm -f src/Makevars src/*.so src/*.dylib src/*.o

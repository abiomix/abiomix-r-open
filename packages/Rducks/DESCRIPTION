Package: Rducks
Title: Register R User-Defined Functions in DuckDB
Version: 0.1.1.9000
Authors@R: c(
    person(given = "Sounkou Mahamane", family = "Toure",
    email = "sounkoutoure@gmail.com", role = c("aut", "cre")),
